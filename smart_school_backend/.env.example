APP_NAME="Smart School Backend"
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

DATABASE_URL=sqlite:///./smart_school.db
# For PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/smart_school

SECRET_KEY=change-this-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DEFAULT_COUNTRY=Uganda
DEFAULT_CURRENCY_CODE=UGX
DEFAULT_TIMEZONE=Africa/Kampala

BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

INITIAL_SUPER_ADMIN_EMAIL=admin@novara.tech
INITIAL_SUPER_ADMIN_PASSWORD=changeme123
INITIAL_SUPER_ADMIN_NAME=Platform Owner

SMS_GATEWAY=console
# For Twilio:
# SMS_GATEWAY=twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+256700000000
